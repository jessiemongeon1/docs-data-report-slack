<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ site_name }} weekly analytics report</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 40px; color: #1f2937; }
    h1, h2, h3 { color: #111827; }
    .muted { color: #6b7280; }
    .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin: 16px 0; }
    ul { line-height: 1.6; }
    pre { white-space: pre-wrap; word-break: break-word; background: #f9fafb; padding: 12px; border-radius: 8px; }
  </style>
</head>
<body>
  <h1>{{ site_name }} weekly analytics report</h1>
  <p class="muted">{{ start_date }} to {{ end_date }} · run {{ run_id }}</p>

  <div class="card">
    <h2>Executive summary</h2>
    <p>{{ final_analysis.executive_summary.summary }}</p>
    <ul>
      {% for item in final_analysis.executive_summary.top_priorities %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </div>

  <div class="card">
    <h2>Notable takeaways</h2>
    {% for item in final_analysis.notable_takeaways %}
      <h3>{{ item.title }} <small>({{ item.priority }})</small></h3>
      <p><strong>Evidence:</strong> {{ item.evidence }}</p>
      <p><strong>Interpretation:</strong> {{ item.interpretation }}</p>
      <p><strong>Action:</strong> {{ item.recommended_action }}</p>
    {% endfor %}
  </div>

  <div class="card">
    <h2>Themes</h2>
    {% for item in final_analysis.themes %}
      <h3>{{ item.name }} <small>({{ item.priority }})</small></h3>
      <p><strong>Why it matters:</strong> {{ item.why_it_matters }}</p>
      <p><strong>Recommended doc action:</strong> {{ item.recommended_doc_action }}</p>
      {% if item.representative_examples %}
      <ul>
        {% for example in item.representative_examples %}
        <li>{{ example }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    {% endfor %}
  </div>

  <div class="card">
    <h2>Sprint recommendations</h2>
    {% for item in final_analysis.sprint_recommendations %}
      <h3>{{ item.title }} <small>({{ item.priority }})</small></h3>
      <p><strong>Scope:</strong> {{ item.scope }}</p>
      <p><strong>Why now:</strong> {{ item.why_now }}</p>
      <p><strong>Expected impact:</strong> {{ item.expected_impact }}</p>
    {% endfor %}
  </div>

  <div class="card">
    <h2>Raw artifacts generated</h2>
    <p>Plausible and Kapa raw JSON were fetched and analyzed automatically before this report was rendered.</p>
  </div>
</body>
</html>
