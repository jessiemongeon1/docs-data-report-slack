<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site_name }} Docs Report · {{ start_date }} to {{ end_date }}</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0c0f14;
  --surface: #141820;
  --surface-2: #1a1f2a;
  --surface-3: #222836;
  --border: #2a3040;
  --border-light: #353d50;
  --text: #e2e6ef;
  --text-muted: #8891a5;
  --text-dim: #5c6478;
  --accent: #4da2ff;
  --accent-dim: rgba(77,162,255,0.12);
  --accent-glow: rgba(77,162,255,0.06);
  --green: #3dd68c;
  --green-dim: rgba(61,214,140,0.12);
  --red: #f0605d;
  --red-dim: rgba(240,96,93,0.12);
  --yellow: #f0c050;
  --yellow-dim: rgba(240,192,80,0.12);
  --orange: #e8844a;
  --purple: #9d7aff;
  --purple-dim: rgba(157,122,255,0.1);
  --radius: 10px;
  --radius-sm: 6px;
  --font: 'DM Sans', -apple-system, sans-serif;
  --font-display: 'Fraunces', Georgia, serif;
  --font-mono: 'JetBrains Mono', monospace;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }

/* Hero */
.hero { padding: 80px 40px 60px; text-align: center; position: relative; overflow: hidden; border-bottom: 1px solid var(--border); }
.hero::before { content: ''; position: absolute; top: -200px; left: 50%; transform: translateX(-50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(77,162,255,0.08) 0%, transparent 70%); pointer-events: none; }
.hero-label { display: inline-block; font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 6px 16px; border-radius: 20px; margin-bottom: 24px; }
.hero h1 { font-family: var(--font-display); font-size: clamp(32px,5vw,56px); font-weight: 700; letter-spacing: -1px; line-height: 1.15; margin-bottom: 12px; }
.hero h1 span { color: var(--accent); }
.hero .subtitle { font-size: 17px; color: var(--text-muted); font-weight: 400; }

/* TOC */
.toc { position: sticky; top: 0; z-index: 100; background: rgba(12,15,20,0.85); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); padding: 0 24px; }
.toc-inner { max-width: 1200px; margin: 0 auto; display: flex; gap: 4px; overflow-x: auto; scrollbar-width: none; padding: 10px 0; }
.toc-inner::-webkit-scrollbar { display: none; }
.toc a { font-size: 12.5px; font-weight: 500; color: var(--text-muted); text-decoration: none; padding: 6px 14px; border-radius: 6px; white-space: nowrap; transition: all 0.2s; }
.toc a:hover { color: var(--text); background: var(--surface-2); }

/* Container + Sections */
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
section { padding: 56px 0; }
section + section { border-top: 1px solid var(--border); }
.section-header { margin-bottom: 36px; }
.section-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
.section-title { font-family: var(--font-display); font-size: clamp(24px,3.5vw,36px); font-weight: 500; letter-spacing: -0.5px; }
.section-desc { color: var(--text-muted); margin-top: 8px; font-size: 15px; max-width: 600px; }

/* Stat Cards */
.stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 12px; margin-bottom: 36px; }
.stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
.stat-card .label { font-size: 12px; color: var(--text-muted); font-weight: 500; margin-bottom: 6px; }
.stat-card .value { font-family: var(--font-display); font-size: 28px; font-weight: 700; letter-spacing: -1px; }
.stat-card .delta { font-size: 12px; margin-top: 4px; color: var(--text-dim); }
.stat-card .delta.up { color: var(--green); }
.stat-card .delta.down { color: var(--red); }

/* Takeaway Cards */
.takeaway-list { display: flex; flex-direction: column; gap: 16px; }
.takeaway { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; border-left: 3px solid var(--accent); }
.takeaway.warn { border-left-color: var(--yellow); }
.takeaway.good { border-left-color: var(--green); }
.takeaway.alert { border-left-color: var(--red); }
.takeaway h4 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.takeaway p { font-size: 14px; color: var(--text-muted); line-height: 1.65; }
.takeaway .evidence { font-family: var(--font-mono); font-size: 12px; color: var(--accent); background: var(--accent-dim); padding: 4px 10px; border-radius: 4px; display: inline-block; margin-bottom: 8px; }
.takeaway .action { font-size: 13px; padding: 10px 14px; background: var(--purple-dim); border-radius: var(--radius-sm); border-left: 3px solid var(--purple); margin-top: 10px; }
.takeaway .action strong { color: var(--purple); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }

/* Theme Cards */
.thread-list { display: flex; flex-direction: column; gap: 14px; }
.thread-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px 24px; transition: border-color 0.2s; }
.thread-card:hover { border-color: var(--border-light); }
.thread-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 8px; flex-wrap: wrap; }
.thread-num { font-family: var(--font-mono); font-size: 11px; font-weight: 600; color: var(--accent); background: var(--accent-dim); padding: 3px 10px; border-radius: 4px; }
.thread-count { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); }
.thread-card h4 { font-size: 14.5px; font-weight: 600; margin-bottom: 6px; }
.thread-card .summary { font-size: 13.5px; color: var(--text-muted); line-height: 1.6; margin-bottom: 10px; }
.action-item { font-size: 13px; padding: 10px 14px; background: var(--purple-dim); border-radius: var(--radius-sm); border-left: 3px solid var(--purple); color: var(--text); line-height: 1.55; }
.action-item strong { color: var(--purple); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }

/* Sprint Cards */
.sprint-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 16px; }
.sprint-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; }
.sprint-card .priority { display: inline-block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; padding: 3px 10px; border-radius: 4px; margin-bottom: 10px; }
.priority.high { background: var(--red-dim); color: var(--red); }
.priority.med  { background: var(--yellow-dim); color: var(--yellow); }
.priority.low  { background: var(--accent-dim); color: var(--accent); }
.sprint-card h4 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.sprint-card p { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 8px; }
.sprint-scope { font-size: 12px; font-family: var(--font-mono); color: var(--text-dim); margin-top: 8px; }
.sprint-impact { font-size: 12px; font-family: var(--font-mono); color: var(--green); margin-top: 4px; }
.sprint-category { display: inline-block; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 2px 8px; border-radius: 4px; background: var(--surface-3); color: var(--text-muted); margin-bottom: 8px; margin-left: 6px; }

/* Data Table */
.data-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
.data-table th { background: var(--surface); color: var(--text-muted); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-family: var(--font-mono); }
.data-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: top; }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: var(--surface-2); }
.data-table th.num, .data-table td.num { text-align: right; font-variant-numeric: tabular-nums; font-family: var(--font-mono); white-space: nowrap; }
.rank { font-family: var(--font-mono); font-size: 11px; color: var(--accent); background: var(--accent-dim); padding: 2px 8px; border-radius: 4px; }
.page-path { font-family: var(--font-mono); font-size: 12px; color: var(--text); }
.page-insight { font-size: 12.5px; color: var(--text-muted); }
.chatbot-badge { display: inline-block; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 2px 8px; border-radius: 4px; background: var(--purple-dim); color: var(--purple); }

/* Tag */
.tag { display: inline-block; font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 4px; background: var(--surface-3); color: var(--text-muted); }

/* Correlation table */
.corr-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
.corr-table th { background: var(--surface); color: var(--text-muted); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-family: var(--font-mono); }
.corr-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); vertical-align: top; }
.corr-table tr:last-child td { border-bottom: none; }
.corr-table tr:hover td { background: var(--surface-2); }

/* Responsive */
@media (max-width: 768px) { .sprint-grid { grid-template-columns: 1fr; } }
@media (max-width: 640px) { .hero { padding: 48px 20px 40px; } .stat-grid { grid-template-columns: repeat(2,1fr); } section { padding: 40px 0; } }
</style>
</head>
<body>

<header class="hero">
  <div class="hero-label">Weekly Docs Report</div>
  <h1>{{ site_name }} <span>Analytics</span></h1>
  <p class="subtitle">{{ start_date }} to {{ end_date }} · Plausible + Kapa · Run {{ run_id }}</p>
</header>

<nav class="toc">
  <div class="toc-inner">
    <a href="#summary">Summary</a>
    <a href="#metrics">Traffic</a>
    <a href="#top-pages">Top Pages</a>
    <a href="#referrals">Referrals</a>
    <a href="#top-referrers">Top Referrer URLs</a>
    <a href="#correlations">Page↔Theme</a>
    <a href="#takeaways">Takeaways</a>
    <a href="#themes">Kapa Themes</a>
    <a href="#kapa-users">User Engagement</a>
    <a href="#sprint">Sprint</a>
  </div>
</nav>

<main class="container">

  {# ── Executive Summary ── #}
  <section id="summary">
    <div class="section-header">
      <div class="section-label">Overview</div>
      <h2 class="section-title">Executive Summary</h2>
    </div>
    <div class="stat-grid">
      <div class="stat-card">
        <div class="label">Kapa Questions</div>
        <div class="value">{{ final_analysis.executive_summary.total_kapa_questions }}</div>
      </div>
      <div class="stat-card">
        <div class="label">Themes Identified</div>
        <div class="value">{{ final_analysis.executive_summary.total_themes_identified }}</div>
      </div>
      {% for m in plausible_analysis.key_metrics %}
      <div class="stat-card">
        <div class="label">{{ m.name }}</div>
        <div class="value">{{ m.value }}</div>
        <div class="delta">{{ m.insight }}</div>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:20px;padding:20px 24px;background:var(--surface);border-radius:8px;border:1px solid var(--border);font-size:15px;line-height:1.7;color:var(--text);">
      {{ final_analysis.executive_summary.summary }}
    </div>
  </section>

  {# ── Traffic Metrics ── #}
  <section id="metrics">
    <div class="section-header">
      <div class="section-label">Plausible</div>
      <h2 class="section-title">Traffic Overview</h2>
      <p class="section-desc">{{ plausible_analysis.summary }}</p>
    </div>
    {% if plausible_analysis.trends %}
    <div class="takeaway-list">
      {% for t in plausible_analysis.trends %}
      <div class="takeaway">
        <h4>{{ t.title }}</h4>
        <p>{{ t.insight }}</p>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </section>

  {# ── Top Pages ── #}
  <section id="top-pages">
    <div class="section-header">
      <div class="section-label">Plausible</div>
      <h2 class="section-title">Top 20 Pages</h2>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Page</th>
          <th>Insight</th>
        </tr>
      </thead>
      <tbody>
        {% for p in plausible_analysis.top_pages %}
        <tr>
          <td><span class="rank">{{ loop.index }}</span></td>
          <td><span class="page-path">{{ p.page }}</span></td>
          <td><span class="page-insight">{{ p.insight }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  {# ── Referrals ── #}
  <section id="referrals">
    <div class="section-header">
      <div class="section-label">Plausible</div>
      <h2 class="section-title">Referral Sources</h2>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th>Source</th>
          <th>Type</th>
          <th>Insight</th>
        </tr>
      </thead>
      <tbody>
        {% for r in plausible_analysis.referrals %}
        <tr>
          <td><span class="page-path">{{ r.source }}</span></td>
          <td>{% if r.is_chatbot_or_agent %}<span class="chatbot-badge">AI / Chatbot</span>{% else %}<span class="tag">Organic</span>{% endif %}</td>
          <td><span class="page-insight">{{ r.insight }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if final_analysis.chatbot_referrals %}
    <div style="margin-top:24px;">
      <div class="section-label" style="margin-bottom:12px;">AI Referral Detail</div>
      <div class="takeaway-list">
        {% for cr in final_analysis.chatbot_referrals %}
        <div class="takeaway" style="border-left-color: var(--purple);">
          <h4>{{ cr.source }}</h4>
          <p>{{ cr.insight }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </section>

  {# ── Top Referrer URLs (raw Plausible data) ── #}
  {% if plausible_raw and plausible_raw.top_referrers and plausible_raw.top_referrers.results %}
  <section id="top-referrers">
    <div class="section-header">
      <div class="section-label">Plausible</div>
      <h2 class="section-title">Top 10 Referrer URLs</h2>
      <p class="section-desc">Exact referring URL or domain and the number of visits driven from each. Direct (no referrer) is excluded.</p>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th>Referrer</th>
          <th class="num">Visitors</th>
          <th class="num">Pageviews</th>
        </tr>
      </thead>
      <tbody>
        {% set ref_count = namespace(n=0) %}
        {% for row in plausible_raw.top_referrers.results %}
          {% if ref_count.n >= 10 %}{% break %}{% endif %}
          {% set referrer = row.dimensions[0] %}
          {% set visitors = row.metrics[0] %}
          {% set pageviews = row.metrics[1] %}
          {% if referrer and referrer != "Direct / None" %}
          {% set ref_count.n = ref_count.n + 1 %}
          <tr>
            <td>
              {% if referrer.startswith('http://') or referrer.startswith('https://') %}
                <a href="{{ referrer }}" target="_blank" rel="noopener noreferrer"><span class="page-path">{{ referrer }}</span></a>
              {% else %}
                <a href="https://{{ referrer }}" target="_blank" rel="noopener noreferrer"><span class="page-path">{{ referrer }}</span></a>
              {% endif %}
            </td>
            <td class="num">{{ visitors }}</td>
            <td class="num">{{ pageviews }}</td>
          </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {# ── Page ↔ Theme Correlations ── #}
  <section id="correlations">
    <div class="section-header">
      <div class="section-label">Cross-Signal</div>
      <h2 class="section-title">Page ↔ Kapa Theme Correlations</h2>
      <p class="section-desc">High-traffic pages mapped to the Kapa themes they correspond to.</p>
    </div>
    <table class="corr-table">
      <thead>
        <tr>
          <th>Page</th>
          <th>Related Kapa Theme</th>
          <th>Insight</th>
        </tr>
      </thead>
      <tbody>
        {% for c in final_analysis.page_theme_correlations %}
        <tr>
          <td><span class="page-path">{{ c.page }}</span></td>
          <td><span class="tag">{{ c.related_kapa_theme }}</span></td>
          <td><span class="page-insight">{{ c.insight }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  {# ── Notable Takeaways ── #}
  <section id="takeaways">
    <div class="section-header">
      <div class="section-label">Analysis</div>
      <h2 class="section-title">Notable Takeaways</h2>
    </div>
    <div class="takeaway-list">
      {% for t in final_analysis.notable_takeaways %}
      {% set modifier = 'alert' if t.priority == 'high' else ('warn' if t.priority == 'medium' else 'good') %}
      <div class="takeaway {{ modifier }}">
        <h4>{{ t.title }}</h4>
        <span class="evidence">{{ t.evidence }}</span>
        <p>{{ t.interpretation }}</p>
      </div>
      {% endfor %}
    </div>
  </section>

  {# ── Kapa Themes ── #}
  <section id="themes">
    <div class="section-header">
      <div class="section-label">Kapa</div>
      <h2 class="section-title">Developer Pain Point Themes</h2>
      <p class="section-desc">{{ kapa_analysis.summary }}</p>
    </div>
    <div class="thread-list">
      {% for t in final_analysis.themes %}
      <div class="thread-card">
        <div class="thread-meta">
          <span class="thread-num">#{{ loop.index }}</span>
          <span class="thread-count">{{ t.evidence_count }} questions</span>
          <span class="tag">{{ t.priority }} priority</span>
        </div>
        <h4>{{ t.name }}</h4>
        <p class="summary">{{ t.why_it_matters }}</p>

        {# Show classified questions for this theme (pre-grouped in Python) #}
        {% set questions = theme_conversations.get(t.name, []) if theme_conversations else [] %}
        {% if questions %}
        <details style="margin-top:12px;">
          <summary style="cursor:pointer;font-size:12px;color:var(--text-muted);font-family:var(--font-mono);letter-spacing:0.5px;">
            Show {{ questions | length }} question{{ 's' if questions | length != 1 else '' }}
          </summary>
          <div style="margin-top:8px;display:flex;flex-direction:column;gap:8px;">
            {% for q in questions %}
            <div style="padding:10px 14px;border:1px solid var(--border);border-radius:6px;font-size:13px;background:var(--surface);">
              <div style="font-weight:600;color:var(--text);margin-bottom:4px;">
                Q: {{ q.question }}
              </div>
              <div style="color:var(--text-muted);font-size:12px;">
                A: {{ q.answer_snippet }}{% if q.answer_snippet | length >= 195 %}…{% endif %}
              </div>
              {% if q.thread_id %}
              <div style="margin-top:6px;">
                <a href="https://app.kapa.ai/threads/{{ q.thread_id }}" target="_blank" rel="noopener"
                   style="font-size:11px;color:var(--accent);text-decoration:none;font-family:var(--font-mono);letter-spacing:0.3px;">
                  View thread &rarr;
                </a>
              </div>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </details>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </section>

  {# ── Kapa User Engagement ── #}
  {% if kapa_user_stats %}
  <section id="kapa-users">
    <div class="section-header">
      <div class="section-label">Kapa</div>
      <h2 class="section-title">User engagement</h2>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:16px;margin-bottom:24px;">
      <div style="flex:1;min-width:140px;text-align:center;padding:16px;border:1px solid var(--border);border-radius:8px;">
        <div style="font-size:28px;font-weight:700;color:var(--text);">{{ kapa_user_stats.total_questions }}</div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Questions asked</div>
      </div>
      <div style="flex:1;min-width:140px;text-align:center;padding:16px;border:1px solid var(--border);border-radius:8px;">
        <div style="font-size:28px;font-weight:700;color:var(--text);">{{ kapa_user_stats.total_identified_users }}</div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Unique users</div>
      </div>
      <div style="flex:1;min-width:140px;text-align:center;padding:16px;border:1px solid var(--border);border-radius:8px;">
        <div style="font-size:28px;font-weight:700;color:var(--text);">{{ kapa_user_stats.returning_user_count }}</div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Returning users (2+ questions)</div>
      </div>
      {% if kapa_user_stats.total_identified_users > 0 %}
      <div style="flex:1;min-width:140px;text-align:center;padding:16px;border:1px solid var(--border);border-radius:8px;">
        <div style="font-size:28px;font-weight:700;color:var(--text);">{{ "%.1f" | format(kapa_user_stats.total_questions / kapa_user_stats.total_identified_users) }}</div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Avg questions per user</div>
      </div>
      {% endif %}
    </div>
    {% if kapa_user_stats.returning_users %}
    <h4 style="font-size:13px;color:var(--text-muted);margin-bottom:8px;">Top returning users</h4>
    <table class="data-table">
      <thead>
        <tr>
          <th>User ID</th>
          <th class="num">Questions</th>
        </tr>
      </thead>
      <tbody>
        {% for u in kapa_user_stats.returning_users %}
        <tr>
          <td><span class="page-path">{{ u.user_id }}</span></td>
          <td class="num">{{ u.questions }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if kapa_user_stats.question_distribution %}
    <div style="margin-top:16px;">
      <h4 style="font-size:13px;color:var(--text-muted);margin-bottom:8px;">Questions per user</h4>
      <table class="data-table">
        <thead>
          <tr>
            <th class="num">Questions</th>
            <th class="num">Users</th>
          </tr>
        </thead>
        <tbody>
          {% for d in kapa_user_stats.question_distribution %}
          <tr>
            <td class="num">{{ d.questions }}</td>
            <td class="num">{{ d.users }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </section>
  {% endif %}

  {# ── Sprint Recommendations ── #}
  <section id="sprint">
    <div class="section-header">
      <div class="section-label">Sprint Planning</div>
      <h2 class="section-title">Recommended Actions</h2>
    </div>

    {% set categories = [
      ('documentation_action',        'Documentation',         'Doc Actions'),
      ('tooling_action',               'Tooling',               'Tooling Actions'),
      ('developer_experience_action',  'Developer Experience',  'DX Actions'),
    ] %}

    {% for cat_key, cat_label, cat_short in categories %}
    {% set items = final_analysis.sprint_recommendations | selectattr('category', 'equalto', cat_key) | list %}
    {% if items %}
    <div style="margin-bottom: 40px;">
      <div class="section-label" style="margin-bottom: 16px;">{{ cat_short }}</div>
      <div class="sprint-grid">
        {% for r in items %}
        <div class="sprint-card">
          <div>
            <span class="priority {{ 'high' if r.priority == 'high' else ('med' if r.priority == 'medium' else 'low') }}">{{ r.priority }}</span>
            <span class="sprint-category">{{ cat_label }}</span>
            {% if r.fact_check_status %}
            {% if r.fact_check_status == 'confirmed' %}
            <span style="font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;background:#dcfce7;color:#166534;">✓ Confirmed</span>
            {% elif r.fact_check_status == 'already_addressed' %}
            <span style="font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;background:#fef3c7;color:#92400e;">Already addressed</span>
            {% elif r.fact_check_status == 'partially_addressed' %}
            <span style="font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;background:#dbeafe;color:#1e40af;">Partial</span>
            {% endif %}
            {% endif %}
          </div>
          <h4>{{ r.title }}</h4>
          <p>{{ r.scope }}</p>
          <p style="color:var(--text-dim);font-size:12px;margin-top:4px;">{{ r.why_now }}</p>
          <div class="sprint-impact">↑ {{ r.expected_impact }}</div>
          {% if r.fact_check_note %}
          <div style="font-size:11px;color:var(--text-muted);margin-top:6px;padding:6px 10px;background:var(--surface-2);border-radius:4px;border-left:2px solid {% if r.fact_check_status == 'confirmed' %}#22c55e{% elif r.fact_check_status == 'already_addressed' %}#f59e0b{% else %}#3b82f6{% endif %};">
            {{ r.fact_check_note }}
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
    {% endfor %}
  </section>

</main>

<footer style="text-align:center;padding:48px 24px;border-top:1px solid var(--border);color:var(--text-dim);font-size:12px;font-family:var(--font-mono);">
  {{ site_name }} Docs Report · {{ start_date }} to {{ end_date }} · Plausible + Kapa · Run {{ run_id }}
</footer>

</body>
</html>
