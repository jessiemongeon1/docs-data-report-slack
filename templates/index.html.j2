<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Docs Analytics Reports</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0c0f14;
  --surface: #141820;
  --surface-2: #1a1f2a;
  --surface-3: #222836;
  --border: #2a3040;
  --border-light: #353d50;
  --text: #e2e6ef;
  --text-muted: #8891a5;
  --text-dim: #5c6478;
  --accent: #4da2ff;
  --accent-dim: rgba(77,162,255,0.12);
  --green: #3dd68c;
  --green-dim: rgba(61,214,140,0.12);
  --radius: 10px;
  --radius-sm: 6px;
  --font: 'DM Sans', -apple-system, sans-serif;
  --font-display: 'Fraunces', Georgia, serif;
  --font-mono: 'JetBrains Mono', monospace;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }

.hero { padding: 80px 40px 60px; text-align: center; position: relative; overflow: hidden; border-bottom: 1px solid var(--border); }
.hero::before { content: ''; position: absolute; top: -200px; left: 50%; transform: translateX(-50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(77,162,255,0.08) 0%, transparent 70%); pointer-events: none; }
.hero-label { display: inline-block; font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 6px 16px; border-radius: 20px; margin-bottom: 24px; }
.hero h1 { font-family: var(--font-display); font-size: clamp(32px,5vw,56px); font-weight: 700; letter-spacing: -1px; line-height: 1.15; margin-bottom: 12px; }
.hero h1 span { color: var(--accent); }
.hero .subtitle { font-size: 17px; color: var(--text-muted); font-weight: 400; }

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
section { padding: 56px 0; }
section + section { border-top: 1px solid var(--border); }
.section-header { margin-bottom: 36px; }
.section-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
.section-title { font-family: var(--font-display); font-size: clamp(24px,3.5vw,36px); font-weight: 500; letter-spacing: -0.5px; }
.section-desc { color: var(--text-muted); margin-top: 8px; font-size: 15px; max-width: 600px; }

.site-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 16px; }
.site-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; transition: border-color 0.2s; }
.site-card:hover { border-color: var(--border-light); }
.site-card h3 { font-size: 18px; font-weight: 600; margin-bottom: 10px; }
.site-card p { font-size: 14px; color: var(--text-muted); line-height: 1.65; margin-bottom: 16px; }
.site-card .btn { display: inline-block; font-size: 13px; font-weight: 600; color: var(--accent); background: var(--accent-dim); padding: 8px 20px; border-radius: var(--radius-sm); text-decoration: none; transition: background 0.2s; }
.site-card .btn:hover { background: rgba(77,162,255,0.2); }

.archive-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
.archive-table th { background: var(--surface); color: var(--text-muted); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-family: var(--font-mono); }
.archive-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: middle; }
.archive-table tr:last-child td { border-bottom: none; }
.archive-table tr:hover td { background: var(--surface-2); }
.archive-table a { color: var(--accent); text-decoration: none; font-size: 12px; font-family: var(--font-mono); }
.archive-table a:hover { text-decoration: underline; }
.run-id { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); }
.current-badge { display: inline-block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 2px 8px; border-radius: 4px; background: var(--green-dim); color: var(--green); margin-left: 8px; vertical-align: middle; }
.report-links { display: flex; gap: 12px; flex-wrap: wrap; }

@media (max-width: 640px) { .hero { padding: 48px 20px 40px; } .site-grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>

<header class="hero">
  <div class="hero-label">Docs Analytics</div>
  <h1>Weekly <span>Reports</span></h1>
  <p class="subtitle">{{ start_date }} to {{ end_date }} · Run {{ run_id }}</p>
</header>

<div class="container">

  {# ── Latest Reports ── #}
  <section id="latest">
    <div class="section-header">
      <div class="section-label">Latest</div>
      <h2 class="section-title">Current Reports</h2>
      <p class="section-desc">Most recent report for each tracked site.</p>
    </div>
    <div class="site-grid">
      {% for site in site_reports %}
      <div class="site-card">
        <h3>{{ site.site_name }}</h3>
        <p>{{ site.final_analysis.executive_summary.summary }}</p>
        <a class="btn" href="latest/{{ site.report_filename }}">Open full report &rarr;</a>
      </div>
      {% endfor %}
    </div>
  </section>

  {# ── Archive ── #}
  {% if past_runs %}
  <section id="archive">
    <div class="section-header">
      <div class="section-label">Archive</div>
      <h2 class="section-title">Previous Reports</h2>
      <p class="section-desc">All previously generated report runs.</p>
    </div>
    <div style="overflow-x:auto;">
      <table class="archive-table">
        <thead>
          <tr>
            <th>Run</th>
            <th>Reports</th>
          </tr>
        </thead>
        <tbody>
          {% for run in past_runs %}
          <tr>
            <td>
              <span class="run-id">{{ run.run_id }}</span>
              {% if run.run_id == run_id %}<span class="current-badge">current</span>{% endif %}
            </td>
            <td>
              <div class="report-links">
                {% for r in run.reports %}
                <a href="{{ run.run_id }}/{{ r.filename }}">{{ r.slug }}</a>
                {% endfor %}
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

</div>

</body>
</html>
