[
  {
    "type": "header",
    "text": { "type": "plain_text", "text": "📊 Weekly Docs Analytics" }
  },
  {
    "type": "context",
    "elements": [
      { "type": "mrkdwn", "text": "{{ start_date }} → {{ end_date }}  ·  Run `{{ run_id }}`" }
    ]
  },
  { "type": "divider" }
  {% for site in site_reports %}
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*{{ site.site_name }}*\n{{ site.final_analysis.executive_summary.summary | replace('\n', ' ') }}"
    }
  }
  ,{
    "type": "section",
    "fields": [
      {
        "type": "mrkdwn",
        "text": "*Conversations analyzed*\n`{{ site.final_analysis.executive_summary.total_kapa_conversations }}`"
      },
      {
        "type": "mrkdwn",
        "text": "*Themes identified*\n`{{ site.final_analysis.executive_summary.total_themes_identified }}`"
      }
    ]
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*🎯 Top priorities*\n{% for item in site.final_analysis.executive_summary.top_priorities %}• {{ item | replace('\n', ' ') }}\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*📌 Notable takeaways*\n{% for t in site.final_analysis.notable_takeaways %}{% set icon = '🔴' if t.priority == 'high' else ('🟡' if t.priority == 'medium' else '🟢') %}{{ icon }} *{{ t.title | replace('\n', ' ') }}*  `{{ t.priority }}`\n   _{{ t.evidence | replace('\n', ' ') }}_\n   → {{ t.recommended_action | replace('\n', ' ') }}\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*🧩 Kapa themes*\n{% for t in site.final_analysis.themes %}• *{{ t.name | replace('\n', ' ') }}* — `{{ t.evidence_count }} convos` `{{ t.priority }}`\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*📝 Doc actions*\n{% for r in site.final_analysis.sprint_recommendations %}{% if r.category == 'documentation_action' %}• *{{ r.title | replace('\n', ' ') }}*  `{{ r.priority }}`\n  {{ r.expected_impact | replace('\n', ' ') }}\n{% endif %}{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*🔧 Tooling actions*\n{% for r in site.final_analysis.sprint_recommendations %}{% if r.category == 'tooling_action' %}• *{{ r.title | replace('\n', ' ') }}*  `{{ r.priority }}`\n  {{ r.expected_impact | replace('\n', ' ') }}\n{% endif %}{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*🧑‍💻 DX actions*\n{% for r in site.final_analysis.sprint_recommendations %}{% if r.category == 'developer_experience_action' %}• *{{ r.title | replace('\n', ' ') }}*  `{{ r.priority }}`\n  {{ r.expected_impact | replace('\n', ' ') }}\n{% endif %}{% endfor %}"
    }
  }
  ,{
    "type": "actions",
    "elements": [
      {
        "type": "button",
        "style": "primary",
        "text": { "type": "plain_text", "text": "Open full report" },
        "url": "{{ site.report_url }}"
      }
    ]
  }
  {% if not loop.last %}
  ,{ "type": "divider" }
  {% endif %}
  {% endfor %}
]
