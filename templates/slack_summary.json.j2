[
  {
    "type": "header",
    "text": {
      "type": "plain_text",
      "text": "Weekly docs analytics"
    }
  },
  {
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Window:* {{ start_date }} to {{ end_date }}"
    }
  }
  {% for site in site_reports %}
  ,{
    "type": "divider"
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*{{ site.site_name }}*\n{{ site.final_analysis.executive_summary.summary | replace('\n', ' ') }}\n\n*{{ site.final_analysis.executive_summary.total_kapa_conversations }} conversations analyzed · {{ site.final_analysis.executive_summary.total_themes_identified }} themes identified*"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Top priorities*\n{% for item in site.final_analysis.executive_summary.top_priorities %}• {{ item }}\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Notable takeaways*\n{% for t in site.final_analysis.notable_takeaways %}• *{{ t.title }}* — {{ t.evidence }} — _{{ t.recommended_action }}_ `{{ t.priority }}`\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Themes*\n{% for t in site.final_analysis.themes %}• *{{ t.name }}* ({{ t.evidence_count }} conversations) — {{ t.why_it_matters }} `{{ t.priority }}`\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Documentation actions*\n{% for r in site.final_analysis.sprint_recommendations | selectattr('category', 'equalto', 'documentation_action') %}• *{{ r.title }}* — {{ r.scope }} — _{{ r.expected_impact }}_ `{{ r.priority }}`\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Tooling actions*\n{% for r in site.final_analysis.sprint_recommendations | selectattr('category', 'equalto', 'tooling_action') %}• *{{ r.title }}* — {{ r.scope }} — _{{ r.expected_impact }}_ `{{ r.priority }}`\n{% endfor %}"
    }
  }
  ,{
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Developer experience actions*\n{% for r in site.final_analysis.sprint_recommendations | selectattr('category', 'equalto', 'developer_experience_action') %}• *{{ r.title }}* — {{ r.scope }} — _{{ r.expected_impact }}_ `{{ r.priority }}`\n{% endfor %}"
    }
  }
  ,{
    "type": "actions",
    "elements": [
      {
        "type": "button",
        "text": {
          "type": "plain_text",
          "text": "Open full report"
        },
        "url": "{{ site.report_url }}"
      }
    ]
  }
  {% endfor %}
]
